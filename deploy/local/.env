# Local development environment variables for orbital.
# Usage: source deploy/local/.env

export ORBITAL_DEV=true
export ORBITAL_LOG_LEVEL=info
export DGRAPH_URL=http://localhost:8080/graphql
export DGRAPH_ADMIN_URL=http://localhost:8080/admin
export ORBITAL_ISSUE_TRACKER_URL="https://dev.azure.com/armadasystems/Commander/_workitems/create/Bug?[System.AreaPath]=Commander\Edge\Edge Platform"
export RATEL_URL=http://localhost:8000
export DGRAPH_SCRATCH_URL=http://localhost:8081/graphql
export DGRAPH_SCRATCH_ADMIN_URL=http://localhost:8081/admin
export DATABASE_URL=postgres://orbital:orbital@localhost:5432/orbital?sslmode=disable
export ORBITAL_EXPORT_DIR=./subgraph-exports
export DGRAPH_SCRATCH_EXPORT_DIR=./subgraph-exports/scratch
export ORBITAL_SCHEMA_PATH=schema/schema-demo.graphql
export ORBITAL_SESSION_SECRET=local-dev-secret
export ORBITAL_OIDC_ISSUER_URL=
export ORBITAL_OIDC_CLIENT_ID=
export ORBITAL_OIDC_CLIENT_SECRET=
export ORBITAL_OIDC_REDIRECT_URL=http://localhost:8001/auth/callback
