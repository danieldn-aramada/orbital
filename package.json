  "dependencies": {
    "bulma": "1.0.4",
    "bulma-toast": "^2.4.4",
    "sass": "^1.77.8"
  },
  "scripts": {
    "build-css": "sass -q --load-path=node_modules web/sass/main.scss web/shared/static/css/main.css",
