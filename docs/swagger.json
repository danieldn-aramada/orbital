{
    "swagger": "2.0",
    "info": {
        "description": "API-first, graph-native configuration management system for modular data centers.",
        "title": "Orbital API",
        "contact": {},
        "version": "0.1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/v1/datacenters/{id}/export": {
            "post": {
                "description": "Triggers an async export of the data center's configuration subgraph. Returns immediately with a job ID. Returns 409 if an export is already in progress for this data center.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "export"
                ],
                "summary": "Trigger subgraph export",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Data center ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/handler.triggerResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/export/jobs": {
            "get": {
                "description": "Returns the 50 most recent export jobs ordered by creation time.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "export"
                ],
                "summary": "List export jobs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/handler.statusResponse"
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/export/jobs/{jobId}": {
            "get": {
                "description": "Returns the current status of an export job.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "export"
                ],
                "summary": "Get export job status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Job ID (UUID)",
                        "name": "jobId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.statusResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        },
        "/api/v1/export/jobs/{jobId}/download": {
            "get": {
                "description": "Downloads the export artifact as a zip archive containing data.json.gz and schema.gz.",
                "produces": [
                    "application/zip"
                ],
                "tags": [
                    "export"
                ],
                "summary": "Download export artifact",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Job ID (UUID)",
                        "name": "jobId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        },
        "/graphql": {
            "post": {
                "description": "POST: proxies GraphQL queries and mutations to DGraph. GET: serves the GraphiQL explorer UI.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "graphql"
                ],
                "summary": "GraphQL endpoint",
                "parameters": [
                    {
                        "example": "\"{\\\"query\\\": \\\"{ queryDataCenter { id name } }\\\"}\"",
                        "description": "GraphQL request body",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.statusResponse": {
            "type": "object",
            "properties": {
                "completedAt": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "dataCenter": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                },
                "jobId": {
                    "type": "string"
                },
                "startedAt": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "handler.triggerResponse": {
            "type": "object",
            "properties": {
                "jobId": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}