{{define "page"}}
  <main class="app-main-grid">
    <div class="app-menu">
      {{template "menu.gohtml" .}}
    </div>
    <div class="app-main p-5">
      {{if not .IsAuthn}}
        <div class="notification is-warning is-light">
          <a class="js-modal-trigger" data-target="login-modal">Login</a> to view this page.
        </div>
      {{else}}

      <p class="is-size-4 mb-2">Divergence Reports</p>
      <p class="has-text-grey mb-5" style="font-size: 0.875rem;">Drift reported by orbs between observed and intended state.</p>

      <div>
        <table id="divergence-report-table" class="table is-striped is-hoverable is-fullwidth">
          <thead>
            <tr>
              <th>Data Center</th>
              <th>Orb</th>
              <th>Reported At</th>
              <th>Status</th>
            </tr>
          </thead>
        </table>
      </div>

      {{end}}
    </div>
  </main>
{{end}}
