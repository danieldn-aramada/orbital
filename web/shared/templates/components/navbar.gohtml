<nav class="navbar is-dark" role="navigation" aria-label="main navigation">

  <div class="navbar-brand">
    <a class="navbar-item" href="{{.BasePath}}/" style="gap: 0.1rem;">
      <img src="{{.BasePath}}/static/logo/logo-armada.png" alt="{{.UI.AppName}} logo">
      <span class="varela-round-regular has-text-white is-size-4"><strong>{{.UI.AppName}}</strong></span>
    </a>

    <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbar-menu">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </a>
  </div>

  <div id="navbar-menu" class="navbar-menu">
    <div class="navbar-start">
      {{if .UI.Tagline}}
      <div class="navbar-item">
        <div class="is-size-7 has-text-grey-light">{{.UI.Tagline}}</div>
      </div>
      {{end}}
      {{if .UI.APIDocPath}}
      <a class="navbar-item" href="{{.UI.APIDocPath}}" target="_blank" rel="noopener">
        <span class="icon-text">
          <span class="icon has-text-info">
            <i class="fa-solid fa-code"></i>
          </span>
          <strong>API</strong>
        </span>
      </a>
      {{end}}

      <a class="navbar-item" href="{{.BasePath}}/graphql" target="_blank" rel="noopener">
        <span class="icon-text">
          <span class="icon has-text-primary">
            <i class="fa-solid fa-diagram-project"></i>
          </span>
          <strong>GraphQL</strong>
        </span>
      </a>

      {{if .RatelURL}}
      {{if eq .RatelURL "#"}}
      <a class="navbar-item todo" href="#">
      {{else}}
      <a class="navbar-item" href="{{.RatelURL}}" target="_blank" rel="noopener">
      {{end}}
        <span class="icon-text">
          <span class="icon has-text-warning">
            <i class="fa-solid fa-bolt"></i>
          </span>
          <strong>DGraph</strong>
        </span>
      </a>
      {{end}}

      {{if .UI.MoreLinks}}
      <div class="navbar-item has-dropdown is-hoverable">
        <a class="navbar-link">
          <span class="icon-text">
            <span class="icon has-text-danger">
              <i class="fa-solid fa-plus"></i>
            </span>
            <strong>More</strong>
          </span>
        </a>
        <div class="navbar-dropdown">
          {{range .UI.MoreLinks}}
          {{if .URL}}
          <a class="navbar-item{{if .IsTodo}} todo{{end}}" href="{{.URL}}" target="_blank" rel="noopener">
            <strong>{{.Label}}</strong>
          </a>
          {{else}}
          <a class="navbar-item" onclick="openReportIssueModal()">
            <strong>{{.Label}}</strong>
          </a>
          {{end}}
          {{end}}
        </div>
      </div>
      {{end}}
    </div>

    {{if .UI.ShowAuth}}
    <div class="navbar-end">
      {{if .IsAuthn}}
        <div class="navbar-item">
          <div class="is-size-7 has-text-grey-light" style="line-height: 1.3;">
            <div class="has-text-weight-semibold has-text-white">{{.User.Name}}</div>
            <div>{{.User.Email}}</div>
          </div>
        </div>
        <div class="navbar-item">
          <form action="{{.BasePath}}/user/logout" method="POST">
            <input type="hidden" name="csrf" value="{{.CsrfToken}}">
            <button class="button is-primary is-outlined theme-dark" type="submit">Logout</button>
          </form>
        </div>
      {{else}}
        <div class="navbar-item">
          <a class="button is-primary is-outlined theme-dark js-modal-trigger" data-target="login-modal">Login</a>
        </div>
      {{end}}
    </div>
    {{end}}
  </div>

</nav>

{{template "todo-toast.gohtml" .}}
{{if .UI.ShowAuth}}{{template "report-issue-modal.gohtml" .}}{{end}}
{{if .UI.ShowAuth}}{{template "login-modal.gohtml" .}}{{end}}
